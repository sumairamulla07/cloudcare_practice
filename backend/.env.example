# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
# PLACEHOLDER: get this from MongoDB Atlas (free tier is fine for a hackathon)
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/cloudcare?retryWrites=true&w=majority
MONGODB_DB_NAME=cloudcare

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Auth (placeholder — replace demo auth with real JWT-based auth)
# ---------------------------------------------------------------------------
# PLACEHOLDER: generate a real secret, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# AWS (only needed once you connect a real sandbox account)
# ---------------------------------------------------------------------------
# PLACEHOLDER: cross-account read role ARN + external ID (see blueprint 2.2 /
# 7.2). Do NOT put long-lived AWS access keys here — use STS assume-role.
AWS_REGION=ap-south-1
AWS_READ_ROLE_ARN=
AWS_EXTERNAL_ID=

# ---------------------------------------------------------------------------
# LLM provider (only needed once Decision/Supervisor agents call a real LLM)
# ---------------------------------------------------------------------------
# PLACEHOLDER: get a key from https://openrouter.ai (or swap for Anthropic/OpenAI directly)
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-3.5-sonnet
