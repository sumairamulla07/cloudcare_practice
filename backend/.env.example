# Copy this file to .env and fill in real values.
# .env is gitignored - never commit real secrets.

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
# PLACEHOLDER: get this from MongoDB Atlas (free tier is fine for a hackathon)
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/cloudcare?retryWrites=true&w=majority
MONGODB_DB_NAME=cloudcare

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
# Local development can set AWS_PROFILE=cloudcare-bootstrap.
# Render should leave AWS_PROFILE blank and use AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY from secret environment variables.
AWS_PROFILE=
AWS_REGION=ap-south-1
AWS_ROLE_ARN=
AWS_READ_ROLE_ARN=
AWS_EXTERNAL_ID=

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-3.5-sonnet

# ---------------------------------------------------------------------------
# Execution safety
# ---------------------------------------------------------------------------
EXECUTION_ENABLED=false
EXECUTION_MODE=simulation
